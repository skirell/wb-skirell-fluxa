			"param_3_name": "Третий блок текста (большой размер)",
			"param_3_desc": "Используется для отображения текста в самом блоке",

			"params_scene_case": "пример: название сценария, комнаты, режима или любой другой текст",
			"params_sensor_case": "пример: температура, влажность",
			"params_switch_case": "пример: название переключателя, комнаты, режима или любой другой текст",

			"icon_scene_case": "пример: weather-night",
