			"max_name": "Максимальная граница для шкалы цветового индикатора",
			"max_desc": "Задаёт максимальное значение в самом блоке",

			"color_1_name": "Цвет индикатора для значений ниже <u>первой границы</u>",
			"color_1_desc": "Используется для определения цветового состояния кругового индикатора при сравнении с текущим значением датчика",

			"color_2_name": "Цвет индикатора для значений между <u>первой</u> и <u>второй границей</u>",
			"color_2_desc": "Используется для определения цветового состояния кругового индикатора при сравнении с текущим значением датчика",

			"color_3_name": "Цвет индикатора для значений выше <u>второй границы</u>",
			"color_3_desc": "Используется для определения цветового состояния кругового индикатора при сравнении с текущим значением датчика",

			"state_topic_name": "Топик для получения данных",
			"state_topic_desc": "MQTT-топик обратной связи, от куда приходят показания от датчика",

			"setting_name": "Название устройства в настройках",
			"setting_name_desc": "Используется для изменения текста заголовка на странице управления устройством",

			"Red": "Красный",
			"Pink": "Розовый",
			"Orange": "Оранжевый",
			"Yellow": "Жёлтый",
			"Mint": "Мятный",
			"Green": "Зелёный",
			"Cyan": "Циановый",
			"Blue": "Голубой",
			"Dark blue": "Синий",
			"Indigo": "Индиго",
