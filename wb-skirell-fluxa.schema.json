{
	"$schema": "http://json-schema.org/draft-04/schema#",
	"type": "object",
	"title": "config_title",

	"configFile": {
		"path": "/etc/wb-skirell-fluxa.conf"
	},

	"properties": {
		"panels": {
			"type": "array",
			"items": {
				"headerTemplate": "panel_title",
				"title": "panel_element",
				"type": "object",
				"properties": {
					"name": {
						"title": "panel_name_title",
						"type": "string",
						"options": {
							"inputAttributes": {
								"placeholder":  "panel_name_case"
							}
						},
						"propertyOrder": 1
					},
					"id": {
						"title": "panel_id_title",
						"type": "string",
						"pattern": "^[0-9A-Fa-f]{12}$",
						"options": {
							"patternmessage": "panel_id_pattern",
							"inputAttributes": {
								"placeholder":  "XXXXXXXXXXXX"
							}
						},
						"propertyOrder": 2
					},
					"screens": {
						"title": "screens_title",
						"type": "array",
						"items": {
							"title": "screens_element",
							"type": "object",
							"properties": {
								"blocks": {
									"title": "blocks_element",
									"type": "array",
									"maxItems": 4,
									"items": {
										"title": "blocks_title",
										"type": "object",
										"oneOf": [
											{"$ref": "#/definitions/block_scene"},
											{"$ref": "#/definitions/block_sensor"},
											{"$ref": "#/definitions/block_switch"}
										],
										"options": {
											"keep_oneof_values": false,
											"disable_collapse": true,
											"disable_edit_json": true,
											"disable_properties": true,
											"wb": {
												"disable_panel": true
											}
										},
										"_format": "wb-multiple"
									},
									"options": {
										"disable_collapse": true,
										"enable_array_copy": true,
										"disable_array_delete_last_row": true
									},
									"_format": "tabs",
									"propertyOrder": 2
								}
							},
							"options": {
								"disable_edit_json": true,
								"disable_properties": true,
								"wb": {
									"disable_title": true
								}
							},
							"_format": "wb-multiple"
						},
						"options": {
							"enable_array_copy": true,
							"disable_collapse": true
						},
						"_format": "tabs-top",
						"propertyOrder": 3
					}
				},
				"options": {
					"disable_edit_json": true,
					"disable_properties": true,
					"collapsed": true
				},
				"required": ["id"],
				"_format": "wb-object"
			},
			"options": {
				"disable_array_delete_last_row": true,
				"disable_array_delete_all_rows": true,
				"enable_array_copy": true,
                "wb": {
					"disable_title": true,
                    "disable_panel": true
                }
			},
			"_format": "wb-multiple"
		}
	},

	"definitions": {
		"color_picker": {
			"type": "string",
			"enum": [
				"color_red",
				"color_pink",
				"color_orange",
				"color_yellow",
				"color_mint",
				"color_green",
				"color_cyan",
				"color_blue",
				"color_dark_blue",
				"color_indigo",
				"color_purple",
				"color_brown",
				"color_white"
			],
			"options": {
				"enum_titles": [
					"Red",
					"Pink",
					"Orange",
					"Yellow",
					"Mint",
					"Green",
					"Cyan",
					"Blue",
					"Dark blue",
					"Indigo",
					"Purple",
					"Brown",
					"White"
				]
			}
		},

		"block_scene": {
			"title": "block_scene_name",
			"type": "object",
			"properties": {
				"type": {
					"type": "string",
					"enum": ["scene"],
					"options": {"hidden": true}
				},
				"param_1": {
					"title": "param_1_name",
					"description": "param_1_desc",
					"type": "string",
					"default": "",
					"options": {
						"show_opt_in": true,
						"inputAttributes": {
							"placeholder": "params_scene_case"
						}
					},
					"propertyOrder": 1
				},
				"param_2": {
					"title": "param_2_name",
					"description": "param_2_desc",
					"type": "string",
					"options": {
						"show_opt_in": true,
						"inputAttributes": {
							"placeholder": "params_scene_case"
						}
					},
					"propertyOrder": 2
				},
				"param_3": {
					"title": "param_3_name",
					"description": "param_3_desc",
					"type": "string",
					"options": {
						"show_opt_in": true,
						"inputAttributes": {
							"placeholder": "params_scene_case"
						}
					},
					"propertyOrder": 3
				},
				"icon": {
					"title": "icon_name",
					"description": "icon_desc",
					"type": "string",
					"minLength": 1,
					"options": {
						"inputAttributes": {
							"placeholder": "icon_scene_case"
						}
					},
					"propertyOrder": 4
				},
				"command_topic": {
					"title": "command_topic_name",
					"description": "command_topic_desc",
					"type": "string",
					"minLength": 1,
					"options": {
						"wb": {
							"data": "devices"
						}
					},
					"_format": "wb-autocomplete",
					"propertyOrder": 5
				},
				"payload": {
					"title": "payload_name",
					"description": "payload_desc",
					"type": "string",
					"minLength": 1,
					"default": "1",
					"options": {
						"inputAttributes": {
							"placeholder": "payload_case"
						}
					},
					"propertyOrder": 6
				}
			},
			"required": ["type", "icon", "command_topic", "payload"]
		},

		"block_sensor": {
			"title": "block_sensor_name",
			"type": "object",
			"properties": {
				"type": {
					"type": "string",
					"enum": ["sensor"],
					"options": {"hidden": true}
				},
				"param_1": {
					"title": "param_1_sensor_name",
					"description": "param_1_sensor_desc",
					"type": "string",
					"options": {
						"show_opt_in": true,
						"inputAttributes": {
							"placeholder": "params_sensor_case"
						}
					},
					"propertyOrder": 1
				},
				"measure": {
					"title": "measure_name",
					"description": "measure_desc",
					"type": "string",
					"options": {
						"show_opt_in": true,
						"inputAttributes": {
							"placeholder": "measure_case"
						}
					},
					"format": "select",
					"propertyOrder": 2
				},
				"min": {
					"title": "min_name",
					"description": "min_desc",
					"type": "integer",
					"default": "",
					"propertyOrder": 3
				},
				"stage_1": {
					"title": "stage_1_name",
					"description": "stage_1_desc",
					"type": "integer",
					"default": "",
					"propertyOrder": 4
				},
				"stage_2": {
					"title": "stage_2_name",
					"description": "stage_2_desc",
					"type": "integer",
					"default": "",
					"propertyOrder": 5
				},
				"max": {
					"title": "max_name",
					"description": "max_desc",
					"type": "integer",
					"default": "",
					"propertyOrder": 6
				},
				"color_1": {
					"title": "color_1_name",
					"description": "color_1_desc",
					"$ref": "#/definitions/color_picker",
					"default": "color_green",
					"minLength": 1,
					"propertyOrder": 7
				},
				"color_2": {
					"title": "color_2_name",
					"description": "color_2_desc",
					"type": "string",
					"$ref": "#/definitions/color_picker",
					"default": "color_yellow",
					"minLength": 1,
					"propertyOrder": 8
				},
				"color_3": {
					"title": "color_3_name",
					"description": "color_3_desc",
					"type": "string",
					"$ref": "#/definitions/color_picker",
					"default": "color_red",
					"minLength": 1,
					"propertyOrder": 9
				},
				"state_topic": {
					"title": "state_topic_name",
					"description": "state_topic_desc",
					"type": "string",
					"minLength": 1,
					"options": {
						"wb": {
							"data": "devices"
						}
					},
					"_format": "wb-autocomplete",
					"propertyOrder": 10
				}
			},
			"required": ["type", "min", "stage_1", "stage_2", "max", "color_1", "color_2", "color_3", "state_topic"]
		},

		"block_switch": {
			"title": "block_switch_name",
			"type": "object",
			"properties": {
				"type": {
					"type": "string",
					"enum": ["switch"],
					"options": {"hidden": true}
				},
				"param_1": {
					"title": "param_1_name",
					"description": "param_1_desc",
					"type": "string",
					"options": {
						"show_opt_in": true,
						"inputAttributes": {
							"placeholder": "params_switch_case"
						}
					},
					"propertyOrder": 1
				},
				"param_2": {
					"title": "param_2_name",
					"description": "param_2_desc",
					"type": "string",
					"options": {
						"show_opt_in": true,
						"inputAttributes": {
							"placeholder": "params_switch_case"
						}
					},
					"propertyOrder": 2
				},
				"icon": {
					"title": "icon_name",
					"description": "icon_desc",
					"type": "string",
					"minLength": 1,
					"options": {
						"inputAttributes": {
							"placeholder": "icon_switch_case"
						}
					},
					"propertyOrder": 3
				},
				"color": {
					"title": "color_name",
					"description": "color_desc",
					"$ref": "#/definitions/color_picker",
					"default": "color_indigo",
					"minLength": 1,
					"propertyOrder": 4
				},
				"OnOff_command_topic": {
					"title": "OnOff_command_topic_name",
					"description": "OnOff_command_topic_desc",
					"type": "string",
					"minLength": 1,
					"options": {
						"wb": {
							"data": "devices"
						}
					},
					"_format": "wb-autocomplete",
					"propertyOrder": 5
				},
				"OnOff_state_topic": {
					"title": "OnOff_state_topic_name",
					"description": "OnOff_state_topic_desc",
					"type": "string",
					"minLength": 1,
					"options": {
						"wb": {
							"data": "devices"
						}
					},
					"_format": "wb-autocomplete",
					"propertyOrder": 6
				},
				"payload_on": {
					"title": "payload_on_name",
					"description": "payload_on_desc",
					"type": "string",
					"minLength": 1,
					"default": "1",
					"options": {
						"inputAttributes": {
							"placeholder": "payload_on_case"
						}
					},
					"propertyOrder": 7
				},
				"payload_off": {
					"title": "payload_off_name",
					"description": "payload_off_desc",
					"type": "string",
					"minLength": 1,
					"default": "0",
					"options": {
						"inputAttributes": {
							"placeholder": "payload_off_case"
						}
					},
					"propertyOrder": 8
				}
			},
			"required": ["type", "icon", "color", "OnOff_command_topic", "OnOff_state_topic", "payload_on", "payload_off"]
		}
	},
	"options": {
		"wb": {
			"disable_title": true
		}
	},

	"translations": {
		"en": {
			"config_title": "Skirell Fluxa panels configurator"
		},
		"ru": {
			"config_title": "Конфигуратор панелей Skirell Fluxa",

			"panel_title": "{{ self.name }} ({{ self.id }})",

			"panel_element": "Панель",
			"panel_name_title": "Наименование панели",
			"panel_name_case": "пример: Гостиная",

			"panel_id_title": "Индентификатор панели",
			"panel_id_pattern": "Допустимо использовать только латинские буквы и цифры. Длина строго 12 символов",

			"screens_element": "Страница",
			"screens_title": "Отображаемые страницы",

			"blocks_element": "Блоки (макс. 4)",
			"blocks_title": "Блок",

			"block_scene_name": "Сценарий",
			"block_sensor_name": "Датчик",
			"block_switch_name": "Переключатель",

			"param_1_name": "Первый блок текста (маленький размер)",
			"param_1_desc": "Используется для отображения текста в самом блоке",
	
			"param_2_name": "Второй блок текста (средний размер)",
