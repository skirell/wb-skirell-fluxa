			"payload_name": "Команда (сообщение) для отправки",
			"payload_desc": "Значение, отправляемое в командный MQTT-топик при нажатии на блок",
			"payload_case": "пример: 1",

			"OnOff_command_topic_name": "Топик для отправки команды",
			"OnOff_command_topic_desc": "Командный MQTT-топик, в который будет отправляться сообщение (команда) при нажатии на блок",

			"OnOff_state_topic_name": "Топик для получения команды",
